<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Beam uses the camera to scan the connection QR code on the presenter screen.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Beam connects to the presenter on your local network.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- Allow cleartext ws:// to the host on the local network (LAN only). -->
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>